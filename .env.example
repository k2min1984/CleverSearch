# OpenSearch
OPENSEARCH_URL=https://localhost:9200
OS_ADMIN=admin
OS_PASSWORD=admin
OPENSEARCH_INDEX=cleversearch-docs

# 민감 정보 AES-256 암호화 키 (운영 환경에서 반드시 변경!)
CREDENTIAL_SECRET=change-this-credential-secret-in-production

# ── App Database (원격 DB 서버 고정) ─────────────────────
DB_TYPE=postgres
DB_HOST=dev.c2r.co.kr
DB_PORT=45432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=dudflgks12!@
DB_SCHEMA=cleversearch_dev

# Ingestion scheduler
INGEST_SCHEDULER_INTERVAL_SECONDS=120
AUTO_START_INGEST_SCHEDULER=false

# Certificate monitor
CERT_DIR=cert

# Optional bootstrap sources (JSON string)
# DB_SOURCES_JSON=[{"name":"mysql-main","db_type":"mysql","connection_url":"mysql+pymysql://user:pass@127.0.0.1:3306/db","query_text":"SELECT id,title,content FROM docs","title_column":"title","chunk_size":500,"is_active":true}]
# SMB_SOURCES_JSON=[{"name":"dept-share","share_path":"\\\\server\\share","username":"domain\\user","password":"secret","is_active":true}]

# JWT auth
JWT_SECRET=change-this-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=1440

# API/Web security
APP_ENV=dev
CORS_ALLOWED_ORIGINS=https://localhost:8000,http://localhost:8000,https://127.0.0.1:8000,http://127.0.0.1:8000,https://localhost:8443,http://localhost:8443,https://127.0.0.1:8443,http://127.0.0.1:8443
ALLOWED_HOSTS=localhost,127.0.0.1
ENABLE_API_DOCS=true
ENABLE_SECURITY_HEADERS=true

# production example
# APP_ENV=production
# ENABLE_API_DOCS=false
# OPENSEARCH_VERIFY_CERTS=true

# Auth brute-force mitigation
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_BLOCK_SECONDS=900

# Search pipeline/scaling options
SEARCH_PIPELINE_VERSION=v1
SEARCH_SHADOW_COMPARE=false
SEARCH_CHOSUNG_QUERY_MODE=wildcard


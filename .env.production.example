# CleverSearch production environment template
# Copy this file to .env on production hosts and replace placeholder secrets.

PROJECT_NAME=CleverSearch
APP_ENV=production

# OpenSearch
OPENSEARCH_URL=https://opensearch.internal:9200
OS_ADMIN=admin
OS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
OPENSEARCH_INDEX=cleversearch-docs
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_SSL_ASSERT_HOSTNAME=true

# App database
DATABASE_URL=postgresql+psycopg2://cleversearch:REPLACE_DB_PASSWORD@postgres.internal:5432/cleversearch
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE_SECONDS=1800

# Scheduler / sources
INGEST_SCHEDULER_INTERVAL_SECONDS=120
AUTO_START_INGEST_SCHEDULER=false
CERT_DIR=cert
DB_SOURCES_JSON=
SMB_SOURCES_JSON=

# JWT auth
JWT_SECRET=REPLACE_WITH_64_PLUS_RANDOM_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=1440

# API/Web security
CORS_ALLOWED_ORIGINS=https://www.example.go.kr,https://search.example.go.kr
ALLOWED_HOSTS=www.example.go.kr,search.example.go.kr
ENABLE_API_DOCS=false
ENABLE_SECURITY_HEADERS=true

# Auth brute-force mitigation
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_BLOCK_SECONDS=900

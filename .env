########################################################
# Description
# 프로젝트 환경 변수 정의 파일
# Docker Compose 및 애플리케이션 설정 값
#
# Modified History
# 강광묵 / 2026-01-20 / 명칭 변경 (HanSeek -> CleverSearch)
########################################################

# 프로젝트 명칭
PROJECT_NAME=CleverSearch

# OpenSearch 접속 정보
# Docker 내부 통신용: https://opensearch:9200
# 로컬 테스트용: https://localhost:9200 (인증서 설정에 따라 다름)
OPENSEARCH_URL=https://localhost:9200

# OpenSearch 계정 정보 (운영 시 변경 필수)
OS_ADMIN=admin
#OS_PASSWORD=Admin123!
OS_PASSWORD=admin

# 메인 인덱스 명칭 (소스코드와 통일)
OPENSEARCH_INDEX=cleversearch-docs

# --------------------------------------------------------
# RDB 설정 (oracle / mysql / postgres)
# 단일: DB=oracle
# 다중: DB=oracle,mysql,postgres
# --------------------------------------------------------
DB=postgres

# Oracle
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=
ORACLE_USER=
ORACLE_PASSWORD=
# ORACLE_DSN=(선택) host/port/service_name 대신 직접 DSN 사용 시 입력
ORACLE_DSN=

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DATABASE=cleversearch_db
POSTGRES_USER=cleversearch
POSTGRES_PASSWORD=dudflgks12!@